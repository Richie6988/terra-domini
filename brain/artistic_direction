{
  "design_system": "HEXOD_TACTICAL_HUD_v26",
  "version": "1.0.0",
  "aesthetic_profile": {
    "theme": "Glassmorphism Tactical HUD",
    "vibe": "Military-grade interface with premium sci-fi aesthetics",
    "contrast_mode": "Light-glass over dark-map",
    "visual_density": "High information density with breathable whitespace"
  },
  "typography": {
    "font_stack": {
      "primary_ui": "'Orbitron', sans-serif",
      "monospace_data": "'Share Tech Mono', monospace",
      "fallback": "system-ui, sans-serif"
    },
    "weights": [400, 500, 600, 700],
    "transform": "UPPERCASE",
    "letter_spacing": {
      "xs": "1px",
      "sm": "2px", 
      "md": "3px",
      "lg": "3px"
    },
    "sizes": {
      "micro": "8px",
      "small": "9px",
      "body": "10px",
      "header": "11px",
      "title": "13px"
    },
    "line_height": 1.2
  },
  "color_palette": {
    "hud_primary": {
      "cyan": "#0099cc",
      "amber": "#cc8800",
      "amber_bright": "#fbbf24"
    },
    "semantic_states": {
      "standby": "#996600",
      "active": "#00884a",
      "scanning": "#00ff55",
      "alert": "#dc2626"
    },
    "glass_system": {
      "bg_primary": "rgba(235, 242, 250, 0.95)",
      "bg_secondary": "rgba(220, 230, 242, 0.95)",
      "bg_card": "rgba(255, 255, 255, 0.4)",
      "bg_cell": "rgba(255, 255, 255, 0.6)",
      "border_subtle": "rgba(0, 60, 100, 0.15)",
      "text_primary": "#1a2a3a",
      "text_accent": "#0077aa"
    },
    "category_codex": {
      "natural_disasters": "#f97316",
      "places_structures": "#6366f1", 
      "nature_geography": "#7c3aed",
      "knowledge_science": "#2563eb",
      "economic_assets": "#64748b",
      "culture_society": "#d946ef",
      "conflict_intrigue": "#dc2626",
      "life_organisms": "#22c55e",
      "fantastic": "#a855f7",
      "game": "#0ea5e9"
    }
  },
  "spatial_system": {
    "grid_unit": "4px",
    "panel_width": "380px",
    "trigger_zone": "48px",
    "icon_grid": {
      "columns": 4,
      "gap": "8px",
      "cell_size": "1:1 aspect-ratio"
    },
    "border_radius": {
      "sharp": 0,
      "micro": "6px",
      "standard": "8px",
      "pill": "20px"
    },
    "z_index": {
      "map_base": 0,
      "scanlines": 9999,
      "trigger": 100,
      "panel": 1000,
      "tooltip": 100,
      "toast": 2000
    }
  },
  "effects_engine": {
    "backdrop_filter": "blur(30px) saturate(1.2)",
    "shadows": {
      "elevation_1": "0 2px 8px rgba(0,50,80,0.1)",
      "elevation_2": "0 4px 12px rgba(0,100,150,0.2)",
      "glow_selected": "0 2px 15px color-mix(in srgb, var(--cat-color) 40%, transparent)",
      "glow_hover": "0 0 14px var(--cat-color)"
    },
    "transitions": {
      "standard": "all 0.35s cubic-bezier(0.16, 1, 0.3, 1)",
      "fast": "all 0.25s ease",
      "panel_slide": "transform 0.5s cubic-bezier(0.16, 1, 0.3, 1)"
    },
    "animations": {
      "pulse": "pulse 2s infinite",
      "scanning_glow": "scanning-glow 1.5s infinite",
      "selected_breathe": "selected-glow 3s infinite ease-in-out",
      "blink": "blink 2s infinite"
    }
  },
  "component_specs": {
    "panel": {
      "bg": "linear-gradient(180deg, rgba(235, 242, 250, 0.95) 0%, rgba(220, 230, 242, 0.95) 100%)",
      "border": "1px solid rgba(0,80,120,0.15)",
      "shadow": "8px 0 30px rgba(0,0,0,0.15), inset -1px 0 0 rgba(255,255,255,0.8)"
    },
    "icon_cell": {
      "idle": {
        "bg": "rgba(255, 255, 255, 0.6)",
        "border": "1px solid rgba(0, 60, 100, 0.1)",
        "scale": 1
      },
      "hover": {
        "scale": 1.6,
        "z_index": 10,
        "border": "2px solid var(--cat-color)",
        "shadow": "0 4px 15px rgba(0,0,0,0.12), 0 0 0 2px var(--cat-color)"
      },
      "selected": {
        "bg": "rgba(255, 255, 255, 0.9)",
        "indicator": "8px dot top-right with glow",
        "animation": "selected_glow"
      }
    },
    "trigger_icon": {
      "idle": {
        "stroke": "#0088bb",
        "opacity": 0.6,
        "animation": "pulse 2.5s infinite"
      },
      "scanning": {
        "stroke": "#00ff55",
        "animation": "scanning-glow 1.5s infinite",
        "filter": "drop-shadow(0 0 6px rgba(0,255,85,0.7))"
      }
    },
    "buttons": {
      "style": "Pill-shaped, glass background",
      "padding": "9px 14px",
      "font": "8px, weight 500, letter-spacing 1px",
      "hover": "translateY(-1px) with elevated shadow"
    },
    "tooltips": {
      "position": "above element, centered",
      "bg": "rgba(20, 35, 50, 0.95)",
      "border": "1px solid var(--cat-color)",
      "arrow": "6px border triangle",
      "backdrop": "blur(8px)"
    }
  },
  "interaction_protocols": {
    "hover_behavior": "Immediate feedback with color inheritance from category",
    "selection_mode": "Toggle with visual persistence (dot indicator)",
    "category_collapse": "Rotate chevron -90deg, hide grid",
    "panel_reveal": "Hover trigger zone 48px from left edge, slide in with spring physics",
    "right_click": "Disabled (contextmenu prevention)"
  },
  "data_visualization": {
    "iconography": {
      "format": "SVG, viewBox 0 0 256 256",
      "container": "Circular mask with colored background",
      "style": "Geometric, 2-3 color max, symbolic representation"
    },
    "status_indicators": {
      "dot": "6px circle, animated opacity or solid glow",
      "count_display": "Bold numeric + 'LOCATED' suffix",
      "toast": "Slide from top, blur backdrop, cyan border"
    }
  },
  "environment": {
    "background": "Animated gradient terrain (#2d5a45 to #1a3d2e)",
    "overlay": "CRT scanline effect (repeating-linear-gradient)",
    "cursor": "Default pointer with custom hover states"
  }
}
