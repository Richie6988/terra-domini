# ─── Dev .env — copy this to .env and start docker compose ──────────────────
DJANGO_SETTINGS_MODULE=terra_domini.settings.dev
DJANGO_SECRET_KEY=dev-secret-key-change-in-production-at-least-50-chars-long

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database
POSTGRES_DB=terradomini
POSTGRES_USER=td_user
POSTGRES_PASSWORD=devpassword123
# POSTGRES_HOST=postgres  # commented: use SQLite in Codespace
POSTGRES_PORT=5432

# Redis
# REDIS_HOST=redis  # commented: use memory cache in Codespace
REDIS_PORT=6379
REDIS_PASSWORD=devredis123
REDIS_DB_CACHE=0
REDIS_DB_CHANNELS=1
REDIS_DB_CELERY=2
REDIS_DB_GAME=3

# MongoDB (optional in dev)
MONGO_USER=td_mongo
MONGO_PASSWORD=devmongo123
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=terradomini

# Kafka (optional in dev — anti-cheat will skip gracefully)
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# Celery
# CELERY_BROKER_URL=  # commented: use sync celery in Codespace
# CELERY_RESULT_BACKEND=  # commented: use sync celery in Codespace

# Flower monitoring
FLOWER_USER=admin
FLOWER_PASSWORD=admin

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=1440
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# Email (console in dev)
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@terradomini.local

# Blockchain — LOCAL HARDHAT NODE (no real crypto needed for dev)
BLOCKCHAIN_CHAIN_ID=31337
BLOCKCHAIN_RPC_URL=http://host.docker.internal:8545
BLOCKCHAIN_RPC_URL_WS=ws://host.docker.internal:8545
TDC_CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
TDC_TREASURY_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
TDC_TREASURY_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
TDC_EUR_RATE=100
TDC_MIN_WITHDRAWAL=50

# Geo
H3_DEFAULT_RESOLUTION=10

# Stripe (test keys — get free at dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Maps (get free token at mapbox.com)
MAPBOX_ACCESS_TOKEN=pk.REPLACE_ME

# AWS S3 (not needed in dev — uses local file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=eu-west-1

# Sentry (leave empty in dev)
SENTRY_DSN=

# Frontend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_TDC_CONTRACT=0x5FbDB2315678afecb367f032d93F642f64180aa3
VITE_CHAIN_ID=31337
