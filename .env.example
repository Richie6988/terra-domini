# ─── Django ──────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-50-char-random-string-in-production
DEBUG=False
ALLOWED_HOSTS=api.terradomini.io,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://terradomini.io,https://www.terradomini.io

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=terradomini
POSTGRES_USER=td_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB_CACHE=0
REDIS_DB_CHANNELS=1
REDIS_DB_CELERY=2
REDIS_DB_GAME=3

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_USER=td_mongo
MONGO_PASSWORD=CHANGE_ME_MONGO_PASSWORD
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=terradomini

# ─── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ─── Celery ──────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/2
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/2

# ─── Flower ──────────────────────────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME_FLOWER_PASSWORD

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# ─── Email ───────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=YOUR_SENDGRID_API_KEY
DEFAULT_FROM_EMAIL=noreply@terradomini.io

# ─── Blockchain / TDC ────────────────────────────────────────────────────────
# Polygon Mainnet (137) or Mumbai Testnet (80001)
BLOCKCHAIN_CHAIN_ID=137
BLOCKCHAIN_RPC_URL=https://polygon-rpc.com
BLOCKCHAIN_RPC_URL_WS=wss://polygon-bor-rpc.publicnode.com
TDC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
TDC_TREASURY_ADDRESS=0x0000000000000000000000000000000000000001
TDC_TREASURY_PRIVATE_KEY=CHANGE_ME_NEVER_COMMIT_THIS
# Rate: 1 EUR = X TDC
TDC_EUR_RATE=100
TDC_MIN_WITHDRAWAL=50

# ─── Maps / Geo ──────────────────────────────────────────────────────────────
MAPBOX_ACCESS_TOKEN=pk.eyJ1...
OSM_OVERPASS_API=https://overpass-api.de/api/interpreter
H3_DEFAULT_RESOLUTION=10

# ─── Sentry ──────────────────────────────────────────────────────────────────
SENTRY_DSN=https://xxxxx@oxxxxx.ingest.sentry.io/xxxxx

# ─── AWS S3 ──────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_STORAGE_BUCKET_NAME=terradomini-media
AWS_S3_REGION_NAME=eu-west-1

# ─── Frontend ────────────────────────────────────────────────────────────────
VITE_API_URL=https://api.terradomini.io
VITE_WS_URL=wss://ws.terradomini.io
