{
  "name": "Terra Domini Dev",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {"version": "20"}
  },
  "postCreateCommand": "bash scripts/codespace_setup.sh",
  "forwardPorts": [8000, 5173],
  "portsAttributes": {
    "8000": {"label": "Django API", "onAutoForward": "notify"},
    "5173": {"label": "Frontend", "onAutoForward": "openBrowser"}
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ms-python.vscode-pylance", "dbaeumer.vscode-eslint"],
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/backend/venv/bin/python",
        "python.terminal.activateEnvironment": true
      }
    }
  }
}
