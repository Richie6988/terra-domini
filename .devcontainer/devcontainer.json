{
  "name": "Terra Domini Dev",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/node:1": {"version": "20"},
    "ghcr.io/devcontainers/features/python:1": {"version": "3.12"}
  },
  "postCreateCommand": "echo '✅ Terra Domini dev container ready. Run: docker compose -f docker-compose.dev.yml up -d'",
  "forwardPorts": [8000, 5173, 5432, 6379, 5555],
  "portsAttributes": {
    "8000": {"label": "Django API"},
    "5173": {"label": "Frontend"},
    "5432": {"label": "PostgreSQL"},
    "5555": {"label": "Celery Flower"}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker",
        "eamodio.gitlens"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true
      }
    }
  }
}
