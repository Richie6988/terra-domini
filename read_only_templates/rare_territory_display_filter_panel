        let selectedIcons = new Set();

        function init() {
            renderCategories();
            setupEvents();
        }

        function renderCategories() {
            const container = document.getElementById('categoriesContainer');
            
            Object.entries(categoriesData).forEach(([catName, catData]) => {
                const div = document.createElement('div');
                div.className = 'category';
                div.style.setProperty('--cat-color', catData.color);
                
                const displayCatName = catName.replace(/_/g, ' ').toUpperCase();
                const iconCount = catData.icons.length;
                
                const cells = catData.icons.map(icon => {
                    const svgContent = svgLibrary[icon.id] || `<svg viewBox="0 0 256 256"><circle cx="128" cy="128" r="90" fill="${catData.color}"/></svg>`;
                    
                    return `
                    <div class="icon-cell" 
                         data-icon-id="${icon.id}" 
                         onclick="toggleIcon('${icon.id}')" 
                         style="--cat-color: ${catData.color}">
                        <div class="icon-svg">${svgContent}</div>
                        <div class="hover-label">
                            <span class="hl-cat">${displayCatName}</span>
                            <span class="hl-name">${icon.name}</span>
                        </div>
                    </div>
                `}).join('');
                
                div.innerHTML = `
                    <div class="category-header" style="--cat-color: ${catData.color}" onclick="toggleCategory(this)">
                        <div class="category-title">
                            ${displayCatName}
                            <span class="category-count">[${iconCount}]</span>
                        </div>
                        <div class="category-toggle">▼</div>
                    </div>
                    <div class="icons-grid">${cells}</div>
                `;
                
                container.appendChild(div);
            });
        }

        function toggleIcon(id) {
            const cell = document.querySelector(`[data-icon-id="${id}"]`);
            if (selectedIcons.has(id)) {
                selectedIcons.delete(id);
                cell.classList.remove('selected');
            } else {
                selectedIcons.add(id);
                cell.classList.add('selected');
            }
            updateStatus();
            debounceSave();
        }

        function toggleCategory(header) {
            header.parentElement.classList.toggle('collapsed');
        }

        function selectAll() {
            document.querySelectorAll('.icon-cell').forEach(c => {
                selectedIcons.add(c.dataset.iconId);
                c.classList.add('selected');
            });
            updateStatus();
            debounceSave();
            showToast('ALL FILTERS ACTIVE');
        }

        function clearAll() {
            selectedIcons.clear();
            document.querySelectorAll('.icon-cell').forEach(c => c.classList.remove('selected'));
            updateStatus();
            debounceSave();
            showToast('FILTERS CLEARED');
        }

        function updateStatus() {
            const count = selectedIcons.size;
            const radar = [];
            for (const category of selectedIcons) {
              const result = radar_detection(category);
              radar.push(result);
              
              // Optional: stop early if condition met
              if (result.threatLevel === 'critical') break;
            }
            document.getElementById('poiCount').textContent = `${radar} LOCATED`;
            
            const status = document.getElementById('systemStatus');
            const trigger = document.getElementById('panel-trigger');
            
            if (count > 0) {
                status.innerHTML = '<span class="status-dot"></span>SCANNING';
                status.classList.add('active');
                trigger.classList.add('scanning');
            } else {
                status.innerHTML = '<span class="status-dot"></span>STANDBY';
                status.classList.remove('active');
                trigger.classList.remove('scanning');
            }
        }

        let saveTimeout;
        function debounceSave() {
            clearTimeout(saveTimeout);
            saveTimeout = setTimeout(saveSettings, 300);
        }

        function saveSettings() {
            const payload = {
                timestamp: new Date().toISOString(),
                activePOITypes: Array.from(selectedIcons),
                count: selectedIcons.size
            };
            window.dispatchEvent(new CustomEvent('poiFilterUpdate', { detail: payload }));
            if (window.mapDisplayManager?.updatePOIFilters) window.mapDisplayManager.updatePOIFilters(payload);
            if (window.parent !== window) window.parent.postMessage({ type: 'POI_FILTER_UPDATE', payload }, '*');
        }

        function showToast(msg) {
            const t = document.getElementById('toast');
            t.textContent = msg;
            t.classList.add('show');
            setTimeout(() => t.classList.remove('show'), 2500);
        }

        function setupEvents() {
            document.getElementById('filter-panel').addEventListener('mouseleave', () => {
                if (selectedIcons.size > 0) saveSettings();
            });
            
            // Prevent right-click
            document.addEventListener('contextmenu', e => e.preventDefault());
        }

        init();
    </script>
